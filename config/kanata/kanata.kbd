;; Island Kanata — CapsLock as Escape (tap) / Hyper (hold)
;;
;; Tap CapsLock quickly → Escape
;; Hold CapsLock + another key → Super+Ctrl (Hyper)
;; Left Alt acts as Ctrl, Left Ctrl acts as Alt
;; All other keys pass through unchanged.

(defcfg
  process-unmapped-keys yes
)

(defsrc
  caps lalt lctl
)

(deflayer default
  @hyper lctl lalt
)

(defalias
  hyper (tap-hold 200 200 esc (multi lmet lctl))
)
