#!/bin/bash
# island:summary=Set the desktop and lock screen wallpaper.
# island:args=<path-to-image>

set -eEo pipefail

if [[ -z "$1" ]]; then
  echo "Usage: island-wallpaper-set <path-to-image>" >&2
  exit 1
fi

WALLPAPER="$(realpath "$1")"

if [[ ! -f "$WALLPAPER" ]]; then
  echo "File does not exist: $WALLPAPER" >&2
  exit 1
fi

STATE_DIR="$HOME/.local/state/island"
mkdir -p "$STATE_DIR"

# Save current wallpaper path
echo "$WALLPAPER" > "$STATE_DIR/current-wallpaper"

# Symlink for easy reference
ln -nsf "$WALLPAPER" "$STATE_DIR/current-wallpaper-link"

# Update desktop background (awww with fade transition)
# Ensure awww daemon is running
if ! awww query &>/dev/null; then
  awww-daemon &>/dev/null & disown
  sleep 0.3
fi

awww img "$WALLPAPER" \
  --transition-type grow \
  --transition-pos center \
  --transition-duration 3 \
  --transition-step 90 \
  --transition-fps 60

# Update lock screen (hyprlock) — set the path in hyprlock.conf
HYPRLOCK="$HOME/.config/hypr/hyprlock.conf"
if [[ -f "$HYPRLOCK" ]]; then
  # Remove existing path line if present, add new one
  WALL_ESCAPED="${WALLPAPER//\\/\\\\}"
  WALL_ESCAPED="${WALL_ESCAPED//&/\\&}"
  if grep -q '^    path' "$HYPRLOCK"; then
    sed -i "s|^    path.*|    path = $WALL_ESCAPED|" "$HYPRLOCK"
  else
    sed -i "/^background {/,/^}/ { /^    monitor/a\\    path = $WALL_ESCAPED
    }" "$HYPRLOCK"
  fi
fi

notify-send -u low "Wallpaper" "Set to $(basename "$WALLPAPER")"
