#!/bin/bash
# island:summary=Restore the last set wallpaper on session start.

STATE_FILE="$HOME/.local/state/island/current-wallpaper"

# Start awww daemon
awww-daemon &>/dev/null & disown
sleep 0.3

if [[ -f "$STATE_FILE" ]]; then
  WALLPAPER="$(cat "$STATE_FILE")"
  if [[ -f "$WALLPAPER" ]]; then
    awww img "$WALLPAPER" --transition-type none
    exit 0
  fi
fi

# No saved wallpaper — set a solid color fallback
awww clear 191724
