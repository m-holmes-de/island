#!/bin/bash
# island:summary=Restore the last set wallpaper on session start.

STATE_FILE="$HOME/.local/state/island/current-wallpaper"

if [[ -f "$STATE_FILE" ]]; then
  WALLPAPER="$(cat "$STATE_FILE")"
  if [[ -f "$WALLPAPER" ]]; then
    setsid swaybg -i "$WALLPAPER" -m fill >/dev/null 2>&1 &
    exit 0
  fi
fi

# No saved wallpaper — start swaybg with a solid color fallback
setsid swaybg -c '#191724' >/dev/null 2>&1 &
