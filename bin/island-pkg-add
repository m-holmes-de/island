#!/bin/bash
# island:summary=Install pacman packages if missing (idempotent).
# island:args=<packages...>

set -eEo pipefail

missing=()
for pkg in "$@"; do
  if ! pacman -Q "$pkg" &>/dev/null; then
    missing+=("$pkg")
  fi
done

if (( ${#missing[@]} == 0 )); then
  exit 0
fi

echo "Installing: ${missing[*]}"
sudo pacman -S --noconfirm --needed "${missing[@]}"
