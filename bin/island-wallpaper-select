#!/bin/bash
# island:summary=Browse ~/wallpapers/ with rofi and set the selected wallpaper.

set -eEo pipefail

ISLAND_PATH="${ISLAND_PATH:-$HOME/.local/share/island}"
WALLPAPER_DIR="${1:-$HOME/wallpapers}"

if [[ ! -d "$WALLPAPER_DIR" ]]; then
  notify-send -u normal "Wallpaper" "Directory not found: $WALLPAPER_DIR"
  exit 1
fi

while true; do
  # Build rofi input: entries with icon metadata for image previews
  rofi_input=""

  # Add parent navigation if we're in a subfolder
  if [[ "$WALLPAPER_DIR" != "$HOME/wallpapers" ]]; then
    rofi_input+=$'..\0icon\x1ffolder\n'
  fi

  # Add directories
  while IFS= read -r dir; do
    name="$(basename "$dir")"
    rofi_input+="${name}/\0icon\x1ffolder\n"
  done < <(find "$WALLPAPER_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)

  # Add image files with preview icons
  while IFS= read -r file; do
    name="$(basename "$file")"
    rofi_input+="${name}\0icon\x1f${file}\n"
  done < <(find "$WALLPAPER_DIR" -mindepth 1 -maxdepth 1 -type f \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' -o -iname '*.bmp' \) 2>/dev/null | sort)

  if [[ -z "$rofi_input" ]]; then
    notify-send -u normal "Wallpaper" "No images found in $WALLPAPER_DIR"
    exit 1
  fi

  # Show rofi with icons
  selected=$(echo -en "$rofi_input" | rofi -dmenu -p "Wallpaper" -i -show-icons \
    -theme-str 'element-icon { size: 64px; }' \
    -theme-str 'listview { lines: 6; }' \
    -theme-str 'element { padding: 8px; }') || exit 0

  if [[ "$selected" == ".." ]]; then
    WALLPAPER_DIR="$(dirname "$WALLPAPER_DIR")"
    continue
  elif [[ "$selected" == */ ]]; then
    WALLPAPER_DIR="$WALLPAPER_DIR/${selected%/}"
    continue
  else
    "$ISLAND_PATH/bin/island-wallpaper-set" "$WALLPAPER_DIR/$selected"
    exit 0
  fi
done
