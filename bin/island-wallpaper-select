#!/bin/bash
# island:summary=Browse ~/wallpapers/ with rofi and set the selected wallpaper.

set -eEo pipefail

WALLPAPER_DIR="${1:-$HOME/wallpapers}"

if [[ ! -d "$WALLPAPER_DIR" ]]; then
  notify-send -u normal "Wallpaper" "Directory not found: $WALLPAPER_DIR"
  exit 1
fi

while true; do
  # Build list: folders first (with / suffix), then image files
  entries=()

  # Add parent navigation if we're in a subfolder
  if [[ "$WALLPAPER_DIR" != "$HOME/wallpapers" ]]; then
    entries+=("..")
  fi

  # Add directories
  while IFS= read -r dir; do
    entries+=("$(basename "$dir")/")
  done < <(find "$WALLPAPER_DIR" -mindepth 1 -maxdepth 1 -type d | sort)

  # Add image files
  while IFS= read -r file; do
    entries+=("$(basename "$file")")
  done < <(find "$WALLPAPER_DIR" -mindepth 1 -maxdepth 1 -type f \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' -o -iname '*.bmp' \) | sort)

  if (( ${#entries[@]} == 0 )); then
    notify-send -u normal "Wallpaper" "No images found in $WALLPAPER_DIR"
    exit 1
  fi

  # Show rofi menu
  selected=$(printf '%s\n' "${entries[@]}" | rofi -dmenu -p "Wallpaper" -i) || exit 0

  if [[ "$selected" == ".." ]]; then
    WALLPAPER_DIR="$(dirname "$WALLPAPER_DIR")"
    continue
  elif [[ "$selected" == */ ]]; then
    # Navigate into subfolder
    WALLPAPER_DIR="$WALLPAPER_DIR/${selected%/}"
    continue
  else
    # Image selected — set it
    island-wallpaper-set "$WALLPAPER_DIR/$selected"
    exit 0
  fi
done
